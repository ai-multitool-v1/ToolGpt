# ============================================================================
# .env.example — NEVER commit a real .env file. Copy this to .env and fill in.
# Use `wrangler pages secret put <NAME>` to set these in production.
# ============================================================================

# ---- Supabase ----
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...         # public, safe to expose (RLS-protected)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # SECRET — server only, NEVER in browser

# ---- AI Providers ----
GROQ_API_KEY=gsk_xxxxxxxxxxxxxx         # https://console.groq.com/keys
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXX       # https://aistudio.google.com/app/apikey

# ---- Telegram Bot ----
# Create a bot via @BotFather, get the token.
# Then message the bot, visit https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your chat_id.
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...
TELEGRAM_CHAT_ID=-1001234567890

# ---- Cron auth ----
# A long random string used to authenticate /api/cron/* requests.
CRON_SECRET=replace-with-64-random-chars

# ---- App config ----
ALLOWED_ORIGINS=https://your-app.pages.dev,https://your-custom-domain.com
APP_URL=https://your-app.pages.dev
ADMIN_EMAILS=you@example.com,another-admin@example.com
